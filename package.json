{
  "name": "jaw-finance",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler d1 migrations apply jaw-finance-local --local && wrangler pages dev --proxy 5173",
    "migrate:local": "echo y | wrangler d1 migrations apply jaw-finance-local --local",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check:ts": "tsc --noEmit",
    "check:tf:fmt": "cd iac && terraform fmt -check",
    "check:tf:validate": "cd iac && terraform validate",
    "check:tf": "pnpm run check:tf:fmt && pnpm run check:tf:validate",
    "check": "pnpm run check:ts && pnpm run check:tf:fmt && pnpm run check:tf",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.21.0",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "husky": "^9.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
